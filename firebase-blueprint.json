{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Extended user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "institution": { "type": "string" },
        "studentLevel": { "type": "string", "enum": ["High School", "University"] },
        "yearGrade": { "type": "string" },
        "cellPhone": { "type": "string" },
        "dateOfBirth": { "type": "string" },
        "address": { "type": "string" },
        "defaultPassMark": { "type": "number", "description": "Default pass mark percentage for modules" },
        "studyPreferences": {
          "type": "object",
          "properties": {
            "preferredStartTime": { "type": "string" },
            "preferredEndTime": { "type": "string" },
            "sessionDuration": { "type": "number" },
            "breakDuration": { "type": "number" }
          }
        },
        "sharedWith": { "type": "array", "items": { "type": "string" } },
        "badges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "icon": { "type": "string" },
              "category": { "type": "string" },
              "unlockedAt": { "type": "string" }
            }
          }
        },
        "studyStats": {
          "type": "object",
          "properties": {
            "currentStreak": { "type": "number" },
            "longestStreak": { "type": "number" },
            "totalStudyHours": { "type": "number" },
            "quizzesCompleted": { "type": "number" },
            "perfectScores": { "type": "number" },
            "modulesCompleted": { "type": "number" },
            "lastStudyDate": { "type": "string" }
          }
        }
      },
      "required": ["uid", "firstName", "lastName", "email", "username", "institution", "studentLevel", "yearGrade", "sharedWith"]
    },
    "Module": {
      "title": "Module",
      "description": "A study module or subject",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "moduleType": { "type": "string", "enum": ["Exam", "Portfolio", "Assessment Only"] },
        "passMark": { "type": "number", "description": "Pass mark percentage for this module" },
        "yearMarkWeight": { "type": "number", "description": "Weight of assignments toward final mark (%)" },
        "examWeight": { "type": "number", "description": "Weight of exam/portfolio toward final mark (%)" },
        "examMark": { "type": "number", "description": "Mark received in exam/portfolio (%)" },
        "examDate": { "type": "string" },
        "portfolioDate": { "type": "string" },
        "assessments": {
          "type": "array",
          "items": { "$ref": "Assessment" }
        },
        "masteryScore": { "type": "number", "description": "Overall module mastery score (0-100)" },
        "videoTranscription": { "type": "string", "description": "Transcript of the video explanation" },
        "learningOutcomes": { "type": "array", "items": { "type": "string" }, "description": "AI identified learning outcomes" },
        "units": {
          "type": "array",
          "items": { "$ref": "StudyUnit" }
        },
        "chatHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "role": { "type": "string", "enum": ["user", "model"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string" }
            },
            "required": ["id", "role", "text", "timestamp"]
          }
        }
      },
      "required": ["id", "title", "moduleType"]
    },
    "Assessment": {
      "title": "Assessment",
      "description": "An assignment or exam task",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "dueDate": { "type": "string" },
        "weight": { "type": "number" },
        "markReceived": { "type": "number" },
        "studyUnits": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "title", "dueDate", "weight"]
    },
    "StudyUnit": {
      "title": "Study Unit",
      "description": "A specific unit or chapter within a module",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "unitNumber": { "type": "string" },
        "name": { "type": "string" },
        "completed": { "type": "boolean", "description": "Whether the unit has been completed" },
        "notes": { "type": "string" },
        "summary": { "type": "string" },
        "learningOutcomes": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "unitNumber", "name", "completed"]
    },
    "Community": {
      "title": "Community",
      "description": "A group for a specific module or subject",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "moduleTitle": { "type": "string" },
        "studentLevel": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "inviteCode": { "type": "string", "description": "Unique code to join the community" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "avatarColor": { "type": "string" },
        "pinnedMessages": { "type": "array", "items": { "type": "object" } },
        "resources": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "name", "moduleTitle", "inviteCode"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a community chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "senderId", "senderName", "text", "timestamp"]
    },
    "StudyLog": {
      "title": "Study Log",
      "description": "A manual record of a study session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "moduleId": { "type": "string" },
        "unitId": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "duration": { "type": "number" },
        "notes": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "moduleId", "startTime", "endTime", "duration", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/modules/{moduleId}": {
      "schema": "Module",
      "description": "User's study modules"
    },
    "/users/{userId}/modules/{moduleId}/assessments/{assessmentId}": {
      "schema": "Assessment",
      "description": "Assessments for a specific module"
    },
    "/users/{userId}/studyLogs/{logId}": {
      "schema": "StudyLog",
      "description": "Manual study logs"
    },
    "/users/{userId}/schedule/{itemId}": {
      "schema": "object",
      "description": "User's study schedule"
    },
    "/communities/{communityId}": {
      "schema": "Community",
      "description": "Community group data"
    },
    "/communities/{communityId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a community"
    }
  }
}
